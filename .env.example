#--------------------------------------------------------------------
# Product Gallery — Environment Configuration Template
# © 2026 RAMRAS TECHNOLOGIES. All Rights Reserved.
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
# Options: development | testing | production
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'https://yourdomain.com/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = product_gallery
database.default.username = db_user
database.default.password = db_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = null
session.cookieName = 'pg_session'

#--------------------------------------------------------------------
# ENCRYPTION KEY
# Generate with: php spark key:generate
#--------------------------------------------------------------------
encryption.key = hex2bin:your_64_character_hex_key_here

#--------------------------------------------------------------------
# EMAIL (SMTP)
#--------------------------------------------------------------------
email.protocol = smtp
email.SMTPHost = smtp.yourmailprovider.com
email.SMTPUser = no-reply@yourdomain.com
email.SMTPPass = your_smtp_password
email.SMTPPort = 587
email.SMTPCrypto = tls
email.fromEmail = no-reply@yourdomain.com
email.fromName  = 'Product Gallery'
email.mailType  = html
